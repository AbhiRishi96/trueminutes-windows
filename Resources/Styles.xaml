<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════
         TrueMinutes Design Tokens — Windows
         Matches macOS DesignTokens.swift (dark-first palette)
         ═══════════════════════════════════════════════════════════ -->

    <!-- Backgrounds -->
    <SolidColorBrush x:Key="BgApp"           Color="#0B0B12"/>
    <SolidColorBrush x:Key="BgCanvas"        Color="#101019"/>
    <SolidColorBrush x:Key="BgElevated"      Color="#1A1A26"/>
    <SolidColorBrush x:Key="BgOverlay"       Color="#18181F"/>
    <SolidColorBrush x:Key="BgOverlayStrong" Color="#22222E"/>

    <!-- Text -->
    <SolidColorBrush x:Key="TextPrimary"   Color="#F2F2F0"/>
    <SolidColorBrush x:Key="TextSecondary" Color="#A8A8A4"/>
    <SolidColorBrush x:Key="TextTertiary"  Color="#737370"/>
    <SolidColorBrush x:Key="TextOnAccent"  Color="#FFFFFF"/>

    <!-- Borders -->
    <SolidColorBrush x:Key="BorderSubtle"  Color="#2A2A38"/>
    <SolidColorBrush x:Key="BorderDefault" Color="#333344"/>

    <!-- Brand Accent — Electric Indigo → Cyan gradient -->
    <SolidColorBrush x:Key="Accent"        Color="#6E56F7"/>
    <SolidColorBrush x:Key="AccentHover"   Color="#5B43E0"/>
    <SolidColorBrush x:Key="AccentSoft"    Color="#201A3A"/>
    <SolidColorBrush x:Key="AccentEnd"     Color="#22D3EE"/>

    <!-- Status -->
    <SolidColorBrush x:Key="Recording"     Color="#E03E3E"/>
    <SolidColorBrush x:Key="RecordingSoft" Color="#3B1C1C"/>
    <SolidColorBrush x:Key="Success"       Color="#0F8A4E"/>
    <SolidColorBrush x:Key="SuccessSoft"   Color="#16291E"/>
    <SolidColorBrush x:Key="Warning"       Color="#D97706"/>
    <SolidColorBrush x:Key="WarningSoft"   Color="#3B2A0E"/>
    <SolidColorBrush x:Key="Failed"        Color="#B42318"/>

    <!-- ═══ Gradients ═══ -->
    <LinearGradientBrush x:Key="AccentGradient" StartPoint="0,0.5" EndPoint="1,0.5">
        <GradientStop Color="#6E56F7" Offset="0"/>
        <GradientStop Color="#22D3EE" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="SidebarHeaderGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#1A1535" Offset="0"/>
        <GradientStop Color="#0E2035" Offset="1"/>
    </LinearGradientBrush>

    <!-- ═══ Corner Radii ═══ -->
    <CornerRadius x:Key="RadiusMd">6</CornerRadius>
    <CornerRadius x:Key="RadiusLg">10</CornerRadius>
    <CornerRadius x:Key="RadiusXl">14</CornerRadius>
    <CornerRadius x:Key="RadiusPill">999</CornerRadius>

    <!-- ═══ Typography ═══ -->
    <Style x:Key="HeadingStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="22"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
    </Style>

    <Style x:Key="SubheadStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
    </Style>

    <Style x:Key="CaptionStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
    </Style>

    <Style x:Key="CaptionTertiaryStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Foreground" Value="{StaticResource TextTertiary}"/>
    </Style>

    <!-- ═══ Card / Panel style ═══ -->
    <Style x:Key="CardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource BgElevated}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderSubtle}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{StaticResource RadiusLg}"/>
        <Setter Property="Padding" Value="16"/>
    </Style>

    <!-- ═══ Accent Button ═══ -->
    <Style x:Key="AccentButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
        <Setter Property="Background" Value="{StaticResource Accent}"/>
        <Setter Property="Foreground" Value="{StaticResource TextOnAccent}"/>
        <Setter Property="CornerRadius" Value="{StaticResource RadiusMd}"/>
        <Setter Property="Padding" Value="16,8"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <!-- ═══ Recording Button ═══ -->
    <Style x:Key="RecordingButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
        <Setter Property="Background" Value="{StaticResource Recording}"/>
        <Setter Property="Foreground" Value="{StaticResource TextOnAccent}"/>
        <Setter Property="CornerRadius" Value="{StaticResource RadiusMd}"/>
        <Setter Property="Padding" Value="16,8"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <!-- ═══ Category Pill ═══ -->
    <Style x:Key="CategoryPillStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource AccentSoft}"/>
        <Setter Property="CornerRadius" Value="{StaticResource RadiusPill}"/>
        <Setter Property="Padding" Value="8,2"/>
    </Style>

    <!-- ═══ Meeting Row Card ═══ -->
    <Style x:Key="MeetingRowStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource BgElevated}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderSubtle}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{StaticResource RadiusLg}"/>
        <Setter Property="Padding" Value="16"/>
        <Setter Property="Margin" Value="0,0,0,8"/>
    </Style>

    <!-- ═══ NavigationView override — dark sidebar ═══ -->
    <SolidColorBrush x:Key="NavigationViewContentGridBorderBrush" Color="Transparent"/>

    <!-- ═══ Section Header Label ═══ -->
    <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="CharacterSpacing" Value="120"/>
        <Setter Property="Foreground" Value="{StaticResource TextTertiary}"/>
        <Setter Property="Margin" Value="0,0,0,8"/>
    </Style>

    <!-- ═══ Separator ═══ -->
    <Style x:Key="SeparatorStyle" TargetType="Border">
        <Setter Property="Height" Value="1"/>
        <Setter Property="Background" Value="{StaticResource BorderSubtle}"/>
        <Setter Property="Margin" Value="0,12"/>
    </Style>
</ResourceDictionary>
