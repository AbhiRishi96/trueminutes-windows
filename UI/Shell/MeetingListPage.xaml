<Page
    x:Class="TrueMinutes.Windows.UI.Shell.MeetingListPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource BgApp}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- header + search -->
            <RowDefinition Height="Auto"/>   <!-- category filter chips -->
            <RowDefinition Height="*"/>      <!-- meeting list -->
        </Grid.RowDefinitions>

        <!-- ── Header + Search ── -->
        <Border Grid.Row="0" Background="{StaticResource BgElevated}"
                BorderBrush="{StaticResource BorderSubtle}"
                BorderThickness="0,0,0,1" Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <AutoSuggestBox x:Name="SearchBox"
                    PlaceholderText="Search meetings…"
                    QueryIcon="Find"
                    TextChanged="OnSearchChanged"
                    MaxWidth="480" HorizontalAlignment="Left"/>

                <TextBlock x:Name="CountLabel"
                    Grid.Column="1" VerticalAlignment="Center"
                    FontSize="11"
                    Foreground="{StaticResource TextTertiary}"/>
            </Grid>
        </Border>

        <!-- ── Category Filter Chips ── -->
        <ScrollViewer Grid.Row="1" HorizontalScrollMode="Enabled"
                      HorizontalScrollBarVisibility="Hidden"
                      VerticalScrollMode="Disabled"
                      Background="{StaticResource BgElevated}"
                      BorderBrush="{StaticResource BorderSubtle}"
                      BorderThickness="0,0,0,1">
            <StackPanel x:Name="FilterChipPanel" Orientation="Horizontal"
                        Spacing="8" Padding="16,8"/>
        </ScrollViewer>

        <!-- ── Meeting List ── -->
        <ScrollViewer Grid.Row="2" Padding="16,12">
            <StackPanel x:Name="MeetingListPanel" Spacing="8">

                <!-- Empty state -->
                <StackPanel x:Name="EmptyState" HorizontalAlignment="Center"
                            VerticalAlignment="Center" Spacing="12"
                            Margin="0,80,0,0">
                    <FontIcon Glyph="&#xE8D4;" FontSize="40"
                              Foreground="{StaticResource Accent}"
                              HorizontalAlignment="Center"/>
                    <TextBlock Text="No meetings yet"
                               FontSize="18" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Join a call in Zoom, Teams, or Meet. TrueMinutes will offer to record from the system tray."
                               FontSize="13"
                               Foreground="{StaticResource TextSecondary}"
                               TextWrapping="Wrap" MaxWidth="360"
                               TextAlignment="Center" HorizontalAlignment="Center"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
